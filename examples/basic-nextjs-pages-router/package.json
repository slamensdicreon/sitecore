{
  "name": "content-sdk-nextjs",
  "description": "Application utilizing Content SDK and Next.js",
  "version": "1.0.0",
  "private": true,
  "config": {
    "appName": "content-sdk-nextjs",
    "graphQLEndpointPath": "/sitecore/api/graph/edge",
    "language": "en",
    "template": "nextjs"
  },
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://doc.sitecore.com/xmc/en/developers/content-sdk/index.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitecore/content-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/sitecore/content-sdk/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@sitecore-content-sdk/analytics-core": "^2.0.0", 
    "@sitecore-content-sdk/personalize": "^2.0.0",
    "@sitecore-content-sdk/events": "^2.0.0",
    "@sitecore-content-sdk/nextjs": "^2.0.0",
    "@sitecore-feaas/clientside": "^0.6.0",
    "@sitecore/components": "~2.1.0",
    "font-awesome": "^4.7.0",
    "next": "^16.2.6",
    "next-localization": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "0.34.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@sitecore-content-sdk/cli": "^2.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.10.4",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "cross-env": "~7.0.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "^4",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "brace-expansion@^5.0.0": "5.0.5",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "flatted": "3.4.2",
    "minimatch@<3.1.3": "3.1.5"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build next:build",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit --incremental false",
    "next:build": "next build --webpack",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev --webpack",
    "next:start": "next start",
    "sitecore-tools:generate-map": "sitecore-tools project component generate-map",
    "sitecore-tools:generate-map:watch": "sitecore-tools project component generate-map --watch",
    "sitecore-tools:build": "sitecore-tools project build",
    "dev": "cross-env NODE_ENV=development npm-run-all --serial sitecore-tools:build --parallel next:dev sitecore-tools:generate-map:watch",
    "start": "cross-env-shell NODE_ENV=production npm-run-all --serial build next:start"
  }
}
